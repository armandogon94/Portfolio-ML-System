# ============================================================
# PORT CONFIGURATION (Project 07 — ML System Portfolio)
# ============================================================
# Host ports follow global convention: 30{NN} for frontend, 80{NN} for backend
# See PORT-MAP.md for full allocation strategy

# Frontend UI
FRONTEND_PORT=3070
STREAMLIT_SERVER_PORT=3000

# Backend API
BACKEND_PORT=8070
API_PORT=8000

# MLflow Tracking
MLFLOW_TRACKING_PORT=5070
MLFLOW_SERVER_PORT=5000

# Service URLs (for development)
MLFLOW_TRACKING_URI=http://localhost:5070
ML_API_URL=http://localhost:8070

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
# PostgreSQL (shared instance, Project 07 uses ml_system_db)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ml_system_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis (shared instance, Project 07 uses DB 7)
REDIS_URL=redis://redis:6379/7
REDIS_DB=7

# ============================================================
# ML MODEL CONFIGURATION
# ============================================================
# Model registry and artifact storage
MLFLOW_BACKEND_STORE_URI=postgresql://postgres:postgres@postgres:5432/ml_system_db
MLFLOW_DEFAULT_ARTIFACT_ROOT=file:///mlflow/artifacts

# Model serving
MODEL_REGISTRY_URI=http://localhost:5070

# ============================================================
# EXPERIMENT TRACKING
# ============================================================
# Weights & Biases API key (optional - get free key at https://wandb.ai)
WANDB_API_KEY=your_key_here

# Set to "offline" to log locally without internet
# WANDB_MODE=offline

# ============================================================
# DEVELOPMENT & DEBUG
# ============================================================
# PyTorch MPS fallback for unsupported operations
PYTORCH_ENABLE_MPS_FALLBACK=1

# Debug mode
DEBUG=false
LOG_LEVEL=INFO

# Streamlit specific settings
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_RUNONSAVE=false
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# ============================================================
# DOCKER COMPOSE
# ============================================================
# Use: docker-compose up
# Dev:  docker-compose -f docker-compose.yml -f docker-compose.dev.yml up
# Prod: docker-compose -f docker-compose.yml up -d
